<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme for Compose - Dark variant -->
    <style name="Theme.Sample" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen theme - Dark variant -->
    <style name="Theme.Sample.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Sample</item>
    </style>

</resources>
